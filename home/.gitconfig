[user]
        name = Cesar Figueroa
        email = cesar.figueroa@me.com
[color]
        ui = true
[core]
        excludesfile = ~/.gitignore
        editor = vim
	pager = less
[alias]
        a = add
        ap = add --patch
        au = add --update
        amend = commit --no-verify --amend -C HEAD
        assume = update-index --assume-unchanged
        no-assume = update-index --no-assume-unchanged
        b = branch --sort=-committerdate
        bm = branch --merged
        c = clone
        cl = clone --depth=1
        cf = commit --no-verify --fixup
        cm = commit --no-verify -m
        co = checkout
        com = checkout main
        cp = cherry-pick
        cv = commit --no-verify --verbose
        d = diff
        ds = diff --staged
        dsw = diff --staged --color-words
        dt = diff-tree -r --name-only --no-commit-id
        dw = diff --color-words
        g = grep --color=always --ignore-case
        h = help
        l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %Cblue<%an>%Creset' --abbrev-commit
        lf = ls-files
        ll = ! git l main..
        p = push
        pb = ! git push --set-upstream origin $(git rev-parse --abbrev-ref HEAD)
        pc = reset --mixed head^
        pf = push --force-with-lease
        pl = pull --ff-only
        pop = reset --mixed HEAD^
        r = rebase
        ra = rebase --abort
        rc = rebase --continue
        rfm = pull --rebase origin main
        ri = rebase --no-verify --interactive
        ris = ! git rebase --no-verify --interactive $(git merge-base main HEAD)
        rl = reflog
        rne = revert --no-edit
        s = status --untracked-files
        sa = stash apply
        sh = show HEAD
        si = status --ignored
        sl = stash list
        sp = stash pop
        ss = show stash
        su = stash --include-untracked
        u = reset HEAD
        ws = diff --check
[credential]
	helper = osxkeychain
[help]
	autocorrect = 0
[push]
	default = simple
[rebase]
	autosquash = true
[diff]
	compactionHeuristic = true
[init]
	defaultBranch = main
